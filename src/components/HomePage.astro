---
import BaseLayout from './BaseLayout.astro';
import { home, site, type Locale } from '../data/site';

type Props = {
  lang?: Locale;
};

const { lang = 'zh-tw' } = Astro.props;
const copy = home[lang] as {
  eyebrow: string;
  title: string;
  subtitle: string;
  primaryCta: string;
  secondaryCta: string;
  themesTitle: string;
  themes: { title: string; text: string }[];
  projectTitle: string;
  projectIntro: string;
  mediaTitle: string;
  mediaIntro: string;
  outcomesTitle: string;
  outcomesIntro: string;
  invitationTitle: string;
  invitationText: string;
};
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL.replace(/\/$/, '');
const path = (value: string) => `${base}${lang === 'en' ? `/en${value === '/' ? '/' : value}` : value}`;
---

<BaseLayout lang={lang} title={lang === 'en' ? 'Home' : undefined} description={site.description[lang]}>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <span class="eyebrow">{copy.eyebrow}</span>
        <h1><span class="highlight-line">{copy.title}</span></h1>
        <p class="hero-lede">{copy.subtitle}</p>
        <div class="hero-actions">
          <a class="button primary" href={path('/projects/')}>{copy.primaryCta}</a>
          <a class="button secondary" href={path('/media/')}>{copy.secondaryCta}</a>
        </div>
      </div>

      <div class="collage" aria-label={lang === 'en' ? 'Hand-drawn media collage placeholder' : '手繪影像拼貼佔位'}>
        <div class="sticky-note">
          {lang === 'en' ? 'Field note' : '現場筆記'}
          <small>{lang === 'en' ? 'Add real activity dates here.' : '之後放正式活動日期。'}</small>
        </div>
        <div class="photo-card large">
          <span class="tape"></span>
          <div class="photo-fill">{lang === 'en' ? 'Featured photo' : '代表照片'}</div>
        </div>
        <div class="photo-card small">
          <span class="tape"></span>
          <div class="photo-fill">{lang === 'en' ? 'Video still' : '影片縮圖'}</div>
        </div>
        <svg class="doodle-arrow" viewBox="0 0 180 80" aria-hidden="true">
          <path d="M12 45 C 42 10, 82 12, 112 38 S 150 62, 168 32" fill="none" stroke="currentColor" stroke-width="5" stroke-linecap="round"></path>
          <path d="M150 24 L170 31 L156 49" fill="none" stroke="currentColor" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </div>
    </div>
  </section>

  <section class="section reveal">
    <div class="container">
      <div class="section-heading">
        <h2>{copy.themesTitle}</h2>
      </div>
      <div class="cards-grid">
        {copy.themes.map((theme, index) => (
          <article class="note-card">
            <span class="card-number">{index + 1}</span>
            <h3>{theme.title}</h3>
            <p>{theme.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section reveal">
    <div class="container">
      <div class="section-heading">
        <h2>{copy.projectTitle}</h2>
        <p>{copy.projectIntro}</p>
      </div>
      <div class="project-strip">
        <article class="project-card">
          <div class="project-thumb">2022</div>
          <div>
            <h3>{lang === 'en' ? 'Rural Reverse-Flow Residency' : '洄游農村駐村'}</h3>
            <p>{lang === 'en' ? 'Cross-departmental summer residency that surfaced moso bamboo as a community specialty and earned the Environmental Sustainability team award.' : '跨系所暑期駐村，發現麻竹筍特產、開發醬筍，獲環境永續獎。'}</p>
          </div>
        </article>
        <article class="project-card">
          <div class="project-thumb">2022</div>
          <div>
            <h3>{lang === 'en' ? 'Food and Farming Intergenerational Camp' : '食農教育代間體驗營'}</h3>
            <p>{lang === 'en' ? 'Elders teach children, both plant and share meals — a complete field-to-table arc, 240+ participations.' : '長輩當小朋友的老師，共耕、共煮、共食，累計 240+ 人次。'}</p>
          </div>
        </article>
        <article class="project-card">
          <div class="project-thumb">2022</div>
          <div>
            <h3>{lang === 'en' ? 'Founding the Co-Prosperity Association' : '協助成立籐惜共好協會'}</h3>
            <p>{lang === 'en' ? 'The community moved from "being served" to "self-development," running its own operations and grants.' : '社區從「被服務」轉「自主發展」，自行運營與申請計畫。'}</p>
          </div>
        </article>
      </div>
      <p class="project-strip-cta">
        <a href={path('/projects/')}>{lang === 'en' ? 'View all projects →' : '看全部計畫與活動 →'}</a>
      </p>
    </div>
  </section>

  <section class="section reveal">
    <div class="container">
      <div class="section-heading">
        <h2>{copy.mediaTitle}</h2>
        <p>{copy.mediaIntro}</p>
      </div>
      <div class="media-wall">
        <div class="media-tile tall">{lang === 'en' ? 'Photo wall' : '照片牆'}</div>
        <div class="media-tile">{lang === 'en' ? 'Workshop' : '工作坊'}</div>
        <div class="media-tile">{lang === 'en' ? 'Community' : '社區現場'}</div>
        <div class="media-tile wide">{lang === 'en' ? 'Featured video embed' : '精選影片嵌入'}</div>
      </div>
    </div>
  </section>

  <section class="section reveal">
    <div class="container scrapbook">
      <div class="section-heading">
        <h2>{copy.outcomesTitle}</h2>
        <p>{copy.outcomesIntro}</p>
      </div>
      <div class="home-stat-grid">
        <article>
          <div class="stat-num">170+</div>
          <div class="stat-label">{lang === 'en' ? '"Vegetable Together" student participations' : '學生「菜一起」累計人次'}</div>
        </article>
        <article>
          <div class="stat-num">300+</div>
          <div class="stat-label">{lang === 'en' ? 'Health promotion participations' : '健康促進累計人次'}</div>
        </article>
        <article>
          <div class="stat-num">240+</div>
          <div class="stat-label">{lang === 'en' ? 'Cross-generation activity participations' : '跨世代活動累計人次'}</div>
        </article>
        <article>
          <div class="stat-num">400+</div>
          <div class="stat-label">{lang === 'en' ? 'Total participations in 2025' : '2025 年度總參與人次'}</div>
        </article>
      </div>
      <p class="project-strip-cta">
        <a href={path('/outcomes/')}>{lang === 'en' ? 'See full outcomes →' : '看完整成果 →'}</a>
      </p>
    </div>
  </section>

  <section class="section reveal">
    <div class="container">
      <div class="invite">
        <h2>{copy.invitationTitle}</h2>
        <p>{copy.invitationText}</p>
      </div>
    </div>
  </section>
</BaseLayout>
