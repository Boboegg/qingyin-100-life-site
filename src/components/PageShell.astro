---
import BaseLayout from './BaseLayout.astro';
import { pageCopy, type Locale } from '../data/site';

type Props = {
  lang?: Locale;
  slug: keyof typeof pageCopy['zh-tw'];
};

const { lang = 'zh-tw', slug } = Astro.props;
const copy = pageCopy[lang][slug];
---

<BaseLayout lang={lang} title={copy.title} description={copy.intro}>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">{lang === 'en' ? 'Page blueprint' : '頁面骨架'}</span>
      <h1>{copy.title}</h1>
      <p class="page-lede">{copy.intro}</p>
    </div>
  </section>

  <section class="section">
    <div class="container page-panel reveal">
      <div class="section-heading">
        <h2>{lang === 'en' ? 'Planned Sections' : '預計區塊'}</h2>
        <p>{lang === 'en' ? 'This first version keeps the structure visible before real materials are added.' : '第一版先讓架構看得見，等正式素材到位再替換內容。'}</p>
      </div>
      <ul class="page-list">
        {copy.sections.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>
</BaseLayout>
